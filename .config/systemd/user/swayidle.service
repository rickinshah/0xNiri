[Unit]
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target

[Service]
ExecStart=/usr/bin/swayidle -w timeout 180 'niri msg action power-off-monitors' timeout 300 'pgrep gtklock || gtklock -d' timeout 600 'systemctl suspend' before-sleep 'playerctl pause && pgrep gtklock || gtklock -d -H -S' after-resume 'sleep 0.5'
Restart=on-failure
