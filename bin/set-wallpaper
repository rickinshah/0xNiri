#!/bin/bash

if [[ -z "$1" || "$1" == "--help" || "$1" == "-h" || "$1" == "-help" ]]; then
    echo "Usage: set-wallpaper /path/to/image"
    echo ""
    echo "Example:"
    echo "  set-wallpaper ~/Pictures/cool-wallpaper.jpg"
    exit 0
fi

if [[ ! -f "$1" ]]; then
    echo "File does not exist at $1"
    exit 1
fi

magick $1 ~/.config/niri/wallpaper.jpg
magick ~/.config/niri/wallpaper.jpg -blur 0x20 ~/.config/niri/blur-wallpaper.jpg

matugen image ~/.config/niri/wallpaper.jpg

color=$(match_color.py "$(jq -r '.colors.primary_container' ~/.config/matugen/colors.json)" \
  | tee /dev/tty \
  | tail -n 1 \
  | jq -r '.selected')
papirus-folders -C $color --theme Papirus-Dark
gio set ~/Videos metadata::custom-icon file:///usr/share/icons/Papirus/48x48/places/folder-$color-videos.svg
if [[ -d ~/Games ]]; then
    gio set ~/Games metadata::custom-icon file:///usr/share/icons/Papirus/48x48/places/folder-$color-games.svg
fi
gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark'

current=$(gsettings get org.gnome.desktop.interface color-scheme)

if [[ "$current" == "'prefer-dark'" ]]; then
    gsettings set org.gnome.desktop.interface color-scheme prefer-light
    gsettings set org.gnome.desktop.interface color-scheme prefer-dark
else
    gsettings set org.gnome.desktop.interface color-scheme prefer-dark
    gsettings set org.gnome.desktop.interface color-scheme prefer-light
fi

awww img -n wallpaper ~/.config/niri/wallpaper.jpg --transition-type=wave --transition-angle=30 --transition-duration=2
awww img -n blur-wallpaper ~/.config/niri/blur-wallpaper.jpg --transition-type=wave --transition-angle=30 --transition-duration=2

systemctl --user restart syshud.service
kitty @ load-config
